# Copy to deploy/homelab/.env and fill in real values.
# Never commit .env. TLS terminates at Caddy/Traefik in front of this stack.

# --- Postgres ---
POSTGRES_USER=galmail
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=galmail
POSTGRES_HOST_PORT=127.0.0.1:5432

# --- API bind (localhost by default; proxy reaches it on the host) ---
API_HOST_PORT=127.0.0.1:8789

# --- Auth (HS256 account JWTs; aud=galmail-homelab) ---
ACCOUNT_AUTH_SECRET=replace-with-long-random-secret
API_ADMIN_TOKEN=replace-with-distinct-admin-token

# --- Apple Push (APNs token auth / .p8) ---
# Apple Developer > Keys > Apple Push Notifications service (APNs)
APNS_TEAM_ID=
APNS_KEY_ID=
# PEM body; use \n for newlines when putting the key on one line
APNS_PRIVATE_KEY=
APNS_TOPIC=com.galateacorp.mail
# true for TestFlight / development devices; false for App Store production
APNS_SANDBOX=true

# --- Android FCM (stub; leave false until wired) ---
FCM_ENABLED=false

# --- Optional AI (OpenAI-compatible: Ollama, vLLM, OpenAI, etc.) ---
# From inside Docker, host.docker.internal reaches the homelab host.
OPENAI_API_BASE=http://host.docker.internal:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=llama3.2

# Must match packages/remote-opt-in REMOTE_OPT_IN_DISCLOSURE_VERSION
CONSENT_DISCLOSURE_VERSION=2026-07-15.v1
PROCESSING_REGION=homelab
RETENTION_MAX_HOURS=168
