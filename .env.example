# GalMail environment template — copy to .env (never commit secrets)

# fixture | live
GALMAIL_PROVIDER_MODE=fixture

# Optional hosted / self-hosted services
GALMAIL_RELAY_URL=http://127.0.0.1:8787
GALMAIL_OPTIN_URL=http://127.0.0.1:8788
VITE_GALMAIL_RELAY_URL=http://127.0.0.1:8787

# Gmail OAuth (restricted scopes — verification required for production)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://127.0.0.1:1420/oauth/gmail/callback

# Microsoft Graph OAuth
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT=common
MS_REDIRECT_URI=http://127.0.0.1:1420/oauth/microsoft/callback

# Blind relay (no mail/tokens — opaque routing only)
RELAY_HMAC_SECRET=dev-only-change-me
RELAY_APNS_KEY_PATH=
RELAY_VAPID_PUBLIC_KEY=
RELAY_VAPID_PRIVATE_KEY=

# Opt-in remote processor (isolated; disabled unless user consents)
OPTIN_TOKEN_ENCRYPTION_KEY=
OPTIN_DEFAULT_RETENTION_HOURS=0
OPTIN_ALLOW_AI=false
